PORT=3001
# Docker Compose default credentials:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/itineraryplanner?schema=public
# If using Postgres.app/local native Postgres, use your local DB user instead:
# DATABASE_URL=postgresql://YOUR_DB_USER@localhost:5432/itineraryplanner?schema=public

# Optional AI integration
OPENAI_API_KEY=

# Optional email integration
RESEND_API_KEY=
RESEND_TEST_TO=delivered@resend.dev

# Auth0 API (JWT validation). When both AUTH0_AUDIENCE and AUTH0_ISSUER_BASE_URL
# are set, the API enforces a valid Auth0 access token on every business route.
# Leave them blank for local dev to use a permissive dev identity (admin).
AUTH0_ISSUER_BASE_URL=https://YOUR_TENANT.us.auth0.com/
AUTH0_AUDIENCE=https://api.itineraryplanner
# Namespace for custom claims added by the Auth0 Action (roles/email/verified).
AUTH0_NAMESPACE=https://itineraryplanner
# Override only if you use a different roles claim than {NAMESPACE}/roles.
AUTH0_ROLES_CLAIM=https://itineraryplanner/roles

# Only accounts on this email domain may use the app. The authoritative check is
# the Auth0 Action; this is defense-in-depth on the API.
ALLOWED_EMAIL_DOMAIN=savacations.com

# Frontend origin(s) allowed by CORS (comma-separated). In production this MUST
# be set to your Netlify domain; otherwise cross-origin requests are rejected.
CORS_ORIGIN=http://localhost:5173

# Set to "production" on Render to enforce CORS + hide internal error details.
NODE_ENV=development
