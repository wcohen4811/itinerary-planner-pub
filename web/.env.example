# Frontend environment (Vite). All VITE_* values are PUBLIC — they are embedded
# in the browser bundle. Never put secrets here.

# Base URL of the deployed API (Render). Leave blank for local dev to use the
# Vite proxy to http://localhost:3001.
VITE_API_URL=

# Auth0 SPA application. When set, the app enforces login via Auth0.
# Leave blank for local dev to use a permissive dev identity (admin).
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=https://api.itineraryplanner
VITE_AUTH0_ROLES_CLAIM=https://itineraryplanner/roles

# Only accounts on this email domain may use the app (client-side gate; the
# authoritative checks live in the Auth0 Action + backend).
VITE_ALLOWED_EMAIL_DOMAIN=savacations.com
